# ============================================================================
# Certificate Intelligence Platform — environment (NAMES/PATHS ONLY, never values)
# Secrets resolve from Vault/KMS at runtime via config.py. This file documents
# which secret PATHS the platform reads. Do not put real secrets here.
# ============================================================================

# --- Run mode ---------------------------------------------------------------
# MOCK = run fully self-contained with simulated adapters + seed data (default).
# LIVE = resolve real credentials from Vault and call real APIs.
CIP_MODE=MOCK

# --- Database (SQLAlchemy URL). SQLite by default; swap to Postgres later. ---
CIP_DATABASE_URL=sqlite:///./data/cip.db
# CIP_DATABASE_URL=postgresql+psycopg://cip:PASS@localhost:5432/cip   # LIVE

# --- Event bus --------------------------------------------------------------
# memory = in-process queue (MOCK).  redis = Redis Streams (LIVE).
CIP_BUS_BACKEND=memory
CIP_REDIS_URL=redis://localhost:6379/0

# --- Secrets backend --------------------------------------------------------
# env = read names below from process env (MOCK). vault = HashiCorp Vault.
CIP_SECRETS_BACKEND=env
CIP_VAULT_ADDR=http://localhost:8200
CIP_VAULT_TOKEN_PATH=secret/data/cip/vault-token

# --- Venafi (paths to secrets in Vault) -------------------------------------
CIP_VENAFI_PLATFORM=VCP                 # TPP | VCP
CIP_VENAFI_BASE_URL=https://api.venafi.cloud
CIP_VENAFI_APIKEY_PATH=secret/data/cip/venafi/apikey
CIP_VENAFI_TPP_TOKEN_PATH=secret/data/cip/venafi/tpp-oauth

# --- Jira -------------------------------------------------------------------
CIP_JIRA_BASE_URL=https://your-org.atlassian.net
CIP_JIRA_USER_PATH=secret/data/cip/jira/user
CIP_JIRA_TOKEN_PATH=secret/data/cip/jira/token
CIP_JIRA_DEFAULT_PROJECT=CERT

# --- Microsoft Teams (incoming webhooks per tier) ---------------------------
CIP_TEAMS_P1_WEBHOOK_PATH=secret/data/cip/teams/p1
CIP_TEAMS_P2_WEBHOOK_PATH=secret/data/cip/teams/p2
CIP_TEAMS_P3_WEBHOOK_PATH=secret/data/cip/teams/p3

# --- CMDB (ServiceNow / Jira Assets) ----------------------------------------
CIP_CMDB_KIND=mock                      # servicenow | jira_assets | mock
CIP_CMDB_BASE_URL=https://your-org.service-now.com
CIP_CMDB_TOKEN_PATH=secret/data/cip/cmdb/token

# --- OpenAI (AI agents — enrichment + routing only) -------------------------
CIP_OPENAI_APIKEY_PATH=secret/data/cip/openai/apikey
CIP_OPENAI_MODEL=gpt-4o-mini

# --- Tool signing (HMAC key path for signed/scoped agent tool calls) --------
CIP_TOOL_SIGNING_KEY_PATH=secret/data/cip/tool-signing-key

# --- API --------------------------------------------------------------------
CIP_API_HOST=0.0.0.0
CIP_API_PORT=8000
CIP_CORS_ORIGINS=http://localhost:3000

# --- Scanner ----------------------------------------------------------------
CIP_SCAN_CRON=0 6 * * *                 # daily 06:00
CIP_SCAN_WINDOWS=7,30,60,90
